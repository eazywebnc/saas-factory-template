# SaaS Factory Template — Environment Variables
# Copy to .env.local and fill in values

# Supabase (shared SaaS Factory project — ALL SaaS use the same Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Cloudflare (for deploy script)
CLOUDFLARE_PAGES_TOKEN=your_pages_token
CLOUDFLARE_DNS_TOKEN=your_dns_token
CLOUDFLARE_ACCOUNT_ID=your_account_id

# Supabase Management API (for deploy script — table creation)
SUPABASE_ACCESS_TOKEN=your_access_token
SUPABASE_PROJECT_REF=your_project_ref

# GitHub (for create-saas.sh — repo creation)
GITHUB_TOKEN=your_github_token
